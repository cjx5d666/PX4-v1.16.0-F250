<launch>
  <param name="/use_sim_time" value="true"/>
  <arg name="enable_rviz" default="true"/>
  <arg name="planner_max_vel" default="1.2"/>
  <arg name="planner_max_acc" default="1.5"/>
  <arg name="planner_horizon" default="8"/>
  <arg name="planner_lambda_collision" default="10.0"/>
  <arg name="planner_dist0" default="0.4"/>
  
  <!-- 地图尺寸建议根据实际场景微调 -->
  <arg name="map_size_x" value="60.0"/>
  <arg name="map_size_y" value="60.0"/>
  <arg name="map_size_z" value="5.0"/>
  
  <arg name="odom_topic" value="/mavros/local_position/odom"/>
  
  <!-- === 核心修正：相机内参，必须与 Gazebo 模型匹配 === -->
  <arg name="cx" value="320.0"/>
  <arg name="cy" value="240.0"/>
  <arg name="fx" value="337.0"/>
  <arg name="fy" value="337.0"/>
  
  <!-- 静态 TF 链，保持原样 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_world_map"
        args="0 0 0 0 0 0 world map" />
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_base_mount"
        args="0.1 0 0 0 0 0 base_link depth_camera_link" />
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_mount_optical"
        args="0 0 0 -1.5707963 0 -1.5707963 depth_camera_link depth_camera_optical_frame" />
  
  <include file="$(find ego_planner)/launch/advanced_param_px4.xml">
    <arg name="map_size_x_" value="$(arg map_size_x)"/>
    <arg name="map_size_y_" value="$(arg map_size_y)"/>
    <arg name="map_size_z_" value="$(arg map_size_z)"/>
    <arg name="odometry_topic" value="$(arg odom_topic)"/>
    
    <arg name="depth_topic" value="/cloud_corrected"/>   <!-- fix_cloud.py 输出 -->
    
    <arg name="cloud_topic" value="/nouse/cloud"/>       <!-- 故意禁用，避免混淆 -->
    <arg name="camera_pose_topic" value="/nouse/pose"/>  <!-- 同上 -->
    
    <arg name="cx" value="$(arg cx)"/>
    <arg name="cy" value="$(arg cy)"/>
    <arg name="fx" value="$(arg fx)"/>
    <arg name="fy" value="$(arg fy)"/>
    
    <arg name="max_vel" value="$(arg planner_max_vel)" />
    <arg name="max_acc" value="$(arg planner_max_acc)" />
    <arg name="planning_horizon" value="$(arg planner_horizon)" />
    <arg name="lambda_collision" value="$(arg planner_lambda_collision)" />
    <arg name="dist0" value="$(arg planner_dist0)" />
    <arg name="use_distinctive_trajs" value="false" />
    <arg name="flight_type" value="1" />
  </include>
  
  <node pkg="ego_planner" name="traj_server" type="traj_server" output="screen">
    <remap from="/position_cmd" to="/planning/pos_cmd"/>
    <remap from="/odom_world" to="$(arg odom_topic)"/>
    <param name="traj_server/time_forward" value="2.0" type="double"/>
  </node>
  
  <node if="$(arg enable_rviz)" name="rviz" pkg="rviz" type="rviz" args="-d $(find ego_planner)/launch/default.rviz" required="true" />
</launch>
